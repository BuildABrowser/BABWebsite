---
import { Image } from 'astro:assets';
import DemoScreenshot from '../assets/demo_screenshot.png';
import StepList from '../components/StepList.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title={"Build a browser!"}>
	<div class="intro-card">
		<h1>BuildABrowser</h1>
		<p>
			BuildABrowser is a project aiming to build a browser and its rendering engine in Java, and then document it
			such that others can rebuild it for themselves.
		</p>
		<span id="demo-links">
			<a href="#demo">Jump to Screenshots</a> |
			<a href="https://youtube.com/">View on <span style="color: #ff0033;">YouTube</span></a>
		</span>
	</div>
	<section class="semicentered section">
		<h2>Download a build:</h2>
		<div id="downloads">
			<a href="download_linux" tabindex="-1"><button class="nav-button ac-2">Linux (Tested on Arch, btw)</button></a>
			<a href="download_windows" tabindex="-1"><button class="nav-button ac-1">Windows (Tested on Windows 11)</button></a>
			<a href="download_android_desktop" tabindex="-1"><button class="nav-button ac-4">Android Desktop (Experimental)</button></a>
		</div>
		<div id="infoblurb">
			<p>
				The Linux/Window builds require a JVM (Java 24 or higher) - I will publish an experimental
				Graal build later, but Graal didn't work very well in my testing.
				For systems not listed, it may be possible (untested) to download the Linux build and pass the
				<span class="small-code">--use-java2d</span> flag.
			</p>
		</div>
	</section>
	<section class="semicentered section">
		<h2>Take a look at some steps:</h2>
		<StepList max={6}/>
		<a href="/steps" tabindex="-1"><button class="nav-button ac-1 all-steps">All Steps</button></a>
	</section>
	<section id="demo" class="section">
		<h2>See a demo!</h2>
		<a href={DemoScreenshot.src}>
			<Image
				src={DemoScreenshot}
				alt="A screenshot containing two BuildABrowser windows"
				width="1920"
				id="demo-screenshot"
			/>
		</a>
	</section>
	<footer>
		Created by Jason Gronn (@EveryOS) | <a href="mailto:jgronn@buildabrowser.net">mailto:jgronn@buildabrowser.net</a><br/>
		Socials
		| <a href="https://github.com/JasonTheKitten/">GitHub</a>
		| <a href="https://www.linkedin.com/in/jason-gronn/">LinkedIn</a>
		| <a href="https://www.deviantart.com/everyos">DeviantArt</a>
		| <a href="https://news.ycombinator.com/user?id=everyos_">Hacker News</a>
		| <a href="https://old.reddit.com/user/everyos/" style="font-size: .75em;">Reddit</a>
		| Discord: everyos
	</footer>
</Layout>

<style>
	.intro-card {
		text-align: center;
		margin: 4em;
	}
	.intro-card p {
		margin: auto;
		max-width: 40em;
	}
	.intro-card h1 {
		font-size: xxx-large;
	}
	.all-steps {
		width: min(80vw, 20em);
		margin-top: 2em;
	}

	#demo-links {
		display: block;
		margin: .5em;
	}
	a {
		color: gray;
	}

	#downloads {
		display: flex;
		flex-wrap: wrap;
		column-gap: 2em;
	}
	#downloads > * {
		flex-grow: 1;
		flex-basis: 25%
	}
	#downloads > a {
		flex-grow: 1;
		text-decoration: none;
	}
	#downloads .nav-button {
		box-sizing: border-box;
		display: block;
		width: 100%;
	}

	#infoblurb p {
		max-width: 55em;
	}

	#demo {
		background-color: var(--color-background-secondary);
		padding: 2em 0;
		text-align: center;
	}
	#demo-screenshot {
		width: clamp(50%, 80em, 100%);
		height: auto;
		margin: auto;
	}

	footer {
		position: sticky;
		bottom: 0;
		padding: 1em;
		margin-top: -1em;
		left: 0;
		width: fit-content;
	}

	footer a {
		color: white;
	}

	@media screen and (max-width: 800px) {
		.intro-card h1 {
			font-size: xx-large;
		}

		footer {
			position: static;
		}

		#downloads > * {
			flex-basis: 100%;
		}
		
		.all-steps {
			box-sizing: border-box;
			width: 100%;
			margin-top: 0;
		}
	}

	@media screen and (prefers-color-scheme: light) {
		body {
			--color-foreground-primary: black;
			--color-background-primary: #FEE;
			--color-background-secondary: #DCCE;
			--color-foreground-small-code: maroon;
		}
	}

	@media screen and (max-width: 2700px) {
		footer {
			background-color: #0008;
		}

		@media (prefers-color-scheme: light) {
			footer {
				background-color: #FFF4;
			}
		}
	}
</style>
